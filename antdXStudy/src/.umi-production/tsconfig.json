{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "sourceMap": true,
    "strict": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@/*": [
        "../../src/*"
      ],
      "@@/*": [
        "../../src/.umi/*"
      ],
      "@umijs/max": [
        "../../node_modules/.pnpm/umi@4.6.54_@babel+core@7.23.6_@types+node@25.8.0_@types+react@18.3.28_eslint@8.35.0_lig_55f4b9c1313fd773b51b96c8a0029342/node_modules/umi"
      ],
      "@umijs/max/typings": [
        "../../src/.umi/typings"
      ]
    }
  },
  "include": [
    "../../.umirc.ts",
    "../../.umirc.*.ts",
    "../../**/*.d.ts",
    "../../**/*.ts",
    "../../**/*.tsx"
  ]
}
