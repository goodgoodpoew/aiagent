# 服务端口
PORT=3001

# === 用户认证 ===
# 生产环境必须设置为高强度随机字符串
AUTH_TOKEN_SECRET=change-me-in-production
# 登录 token 有效期，默认 7 天
AUTH_TOKEN_TTL_SECONDS=604800
# 是否允许开发/测试通过 X-User-Id 指定身份。生产保持 false。
AUTH_ALLOW_HEADER_USER_ID=false

# === CORS ===
# 多个来源用英文逗号分隔；生产环境禁止配置为 * 且 credentials=true。
CORS_ORIGINS=http://localhost:8000,http://localhost:5173,http://localhost:3000

# === AI 平台 API Keys ===

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Anthropic Claude
CLAUDE_API_KEY=sk-ant-your-claude-key

# Google Gemini
GEMINI_API_KEY=your-gemini-key

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# === 缓存 TTL（秒） ===
CACHE_TTL_CHAT=300
CACHE_TTL_SESSION=3600

# === 速率限制 ===
THROTTLE_TTL=60000
THROTTLE_LIMIT=20

# === 文件上传 ===
# 单文件最大字节数（默认 10485760 = 10 MB）
FILE_MAX_SIZE=10485760
# 单条消息最大附件数
FILE_MAX_ATTACHMENTS_PER_MESSAGE=5
